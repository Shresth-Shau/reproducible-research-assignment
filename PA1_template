.component-toast { top: 0px; left: 0px; width: 100%; text-align: center; z-index: 1040; }

.component-toast, .component-toast.in-container { position: absolute; }

.component-toast .toast-body { position: relative; display: inline-flex; font-size: 12px; white-space: pre-wrap; color: rgb(255, 255, 255); max-width: calc(100% - 32px); overflow: hidden; padding: 8px 16px; border-radius: 4px; background: rgba(37, 37, 37, 0.9); align-items: flex-start; justify-content: space-between; }

.component-toast .toast-body.toast-in { animation: 0.2s ease 0s 1 normal none running toast-in; }

.component-toast .toast-body.toast-out { animation: 0.2s ease 0s 1 normal none running toast-out; }

.component-toast .toast-body .toast-kd-icon { margin-right: 12px; }

.component-toast .toast-body .toast-kd-icon.toast-kd-icon-loading-white { animation: 0.8s linear 0s infinite normal none running spinning; margin-top: 0px; }

.component-toast .toast-body .toast-button { color: rgb(67, 140, 250); margin-left: 16px; display: inline-block; text-align: start; max-width: 40%; }

.component-toast .toast-body .toast-adjust-test { margin-right: 16px; text-align: start; flex: 1 1 0%; }

.component-toast .toast-swipeable { touch-action: pan-y; cursor: grab; position: relative; }

.component-toast .toast-swipeable:active { cursor: grabbing; }

.component-toast .toast-swipeable[style*="translateY"] { box-shadow: 0 4px 20px rgba(var(--kd-color-black),.15); }

.component-toast .new-toast-body { position: relative; display: inline-flex; font-size: 14px; white-space: pre-wrap; color: rgb(255, 255, 255); max-width: calc(100% - 32px); overflow: hidden; padding: 14px 16px; border-radius: 12px; background: rgba(37, 37, 37, 0.9); justify-content: space-between; min-height: 50px; }

.component-toast .new-toast-body.toast-in { animation: 0.2s ease 0s 1 normal none running toast-in; }

.component-toast .new-toast-body.toast-out { animation: 0.2s ease 0s 1 normal none running toast-out; }

.component-toast .new-toast-body .toast-kd-icon { margin-right: 8px; }

.component-toast .new-toast-body .toast-kd-icon.toast-kd-icon-loading-white { margin-top: -4px; animation: 0.8s linear 0s infinite normal none running spinning; }

.component-toast .new-toast-body .toast-button { color: var(--blue-kd-color-blue-4,#74a9fd); margin-left: 16px; display: inline-block; text-align: start; max-width: 40%; font-weight: 600; }

