.component-toast .new-toast-body .toast-close { margin-left: 16px; }

.component-toast .new-toast-full-width { width: 100%; }

@keyframes toast-in { 
  0% { opacity: 0; transform: translate3d(0px, -50%, 0px); }
  100% { opacity: 1; transform: translateZ(0px); }
